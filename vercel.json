{
  "cleanUrls": true,
  "functions": {
    "api/admin/llamadas-automaticas.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/admin/llamadas-automaticas",
      "schedule": "0 14 * * 1-5"
    }
  ],
  "rewrites": [
    {
      "source": "/boleta/:numero",
      "destination": "/boleta"
    },
    {
      "source": "/diarias",
      "destination": "/diarias.html"
    },
    {
      "source": "/diarias3",
      "destination": "/diarias3.html"
    },
    {
      "source": "/rendimiento",
      "destination": "/rendimiento.html"
    },
    {
      "source": "/finanzas",
      "destination": "/finanzas.html"
    }
  ]
}
