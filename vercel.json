{
  "cleanUrls": true,
  "buildCommand": "node scripts/build-jsx.mjs",
  "headers": [
    {
      "source": "/vendor/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*)\\.(css|jsx|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, stale-while-revalidate=3600"
        }
      ]
    }
  ],
  "functions": {
    "api/contenido/transcribir.js": {
      "maxDuration": 120
    },
    "api/whatsapp/respuestas-rapidas.js": {
      "maxDuration": 60
    },
    "api/whatsapp/agente.js": {
      "maxDuration": 30
    },
    "api/whatsapp/recibir.js": {
      "maxDuration": 30
    },
    "api/whatsapp/agente-responder.js": {
      "maxDuration": 300
    },
    "api/whatsapp/verificar-pagos-cron.js": {
      "maxDuration": 300
    },
    "api/whatsapp/difusiones-cron.js": {
      "maxDuration": 60
    },
    "api/admin/llamadas-automaticas.js": {
      "maxDuration": 60
    },
    "api/admin/difusion-llamadas.js": {
      "maxDuration": 60
    },
    "api/admin/conciliar-consolidado.js": {
      "maxDuration": 30
    },
    "api/whatsapp/alertas-cron.js": {
      "maxDuration": 30
    },
    "api/whatsapp/probar-suite.js": {
      "maxDuration": 120
    }
  },
  "crons": [],
  "redirects": [
    {
      "source": "/ver-mi-boleta-la-plata-house",
      "destination": "/boleta",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/boleta/:numero",
      "destination": "/boleta"
    },
    {
      "source": "/rendimiento",
      "destination": "/rendimiento.html"
    },
    {
      "source": "/rendimiento-contenido",
      "destination": "/rendimiento-contenido/index.html"
    },
    {
      "source": "/rifas",
      "destination": "/rifas.html"
    },
    {
      "source": "/estado-resultados",
      "destination": "/estado-resultados.html"
    },
    {
      "source": "/calendario",
      "destination": "/calendario.html"
    },
    {
      "source": "/admin-horarios",
      "destination": "/admin-horarios.html"
    },
    {
      "source": "/llamadas",
      "destination": "/llamadas.html"
    },
    {
      "source": "/sorteo",
      "destination": "/sorteo.html"
    },
    {
      "source": "/permisos",
      "destination": "/permisos.html"
    }
  ]
}